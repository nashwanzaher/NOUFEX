{
  "name": "@noufex/ui-tokens",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": "./dist/tailwind-preset.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-css.cjs",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2"
  }
}
